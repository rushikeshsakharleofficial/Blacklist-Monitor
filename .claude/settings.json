{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "mcp__chrome-devtools__*",
      "mcp__code-outline__*",
      "mcp__plugin_ssh-ops_code-outline__*",
      "mcp__stitch__*",
      "mcp__plugin_figma_figma__*",
      "mcp__claude_ai_Google_Drive__*"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "code-outline-graph update . 2>/dev/null; true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "code-outline-graph update . 2>/dev/null; true"
          }
        ]
      }
    ]
  }
}